### Copy this file to `.env` and fill values before running the app

# API keys
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key

# Redis (used by Celery). When running locally without Redis, the app will
# fall back to an in-memory stub for light usage.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
